{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "gitlab>sylva-projects/sylva-elements/renovate-config:default"
  ],
  "ignorePaths": [],
  "baseBranches": [
    "main",
    "release-1.3"
  ],
  "addLabels": [
    "renovate"
  ],
  "gitlabci": {
    "managerFilePatterns": [
      "/\\.gitlab/ci/.*.yml/"
    ]
  },
  "gitlabci-include": {
    "managerFilePatterns": [
      "/\\.gitlab/ci/.*.yml/"
    ]
  },
  "kubernetes": {
    "managerFilePatterns": [
      "/kustomize-units/.+\\.yaml/"
    ],
    "ignorePaths": [
      "kustomize-units/**/kustomization.yaml"
    ]
  },
  "packageRules": [
    {
      "description": "For release-1.3 base branch, disable major/minor to only keep patch updates",
      "matchUpdateTypes": [
        "major",
        "minor"
      ],
      "matchBaseBranches": [
        "release-1.3"
      ],
      "enabled": false
    },
    {
      "description": "For release-1.3, limit updates frequency to every 2 weeks",
      "matchBaseBranches": [
        "release-1.3"
      ],
      "matchPackageNames": [
        "!/.*sylva.*/"
      ],
      "schedule": [
        "* * 11,26 * *"
      ]
    },
    {
      "description": "Limit patch updates frequency to every 2 weeks for some packages",
      "matchPackageNames": [
        "thanos",
        "postgresql"
      ],
      "matchUpdateTypes": [
        "patch"
      ],
      "schedule": [
        "* * 1,14 * *"
      ]
    },
    {
      "description": "Regroup CAPI and capd-manager updates",
      "matchPackageNames": [
        "gcr.io/k8s-staging-cluster-api/capd-manager",
        "kubernetes-sigs/cluster-api"
      ],
      "groupName": "cluster-api & capd-manager"
    },
    {
      "description": "Regroup vsphere-cloud-controller-manager updates",
      "matchFileNames": [
        "kustomize-units/vsphere-cloud-controller-manager/**"
      ],
      "groupName": "cloud-provider-vsphere",
      "matchPackageNames": [
        "gcr.io/cloud-provider-vsphere/csi/release{/,}**",
        "quay.io/k8scsi{/,}**"
      ]
    },
    {
      "description": "Regroup vsphere-csi-driver updates",
      "matchFileNames": [
        "kustomize-units/vsphere-csi-driver/**"
      ],
      "groupName": "vsphere-csi-driver",
      "matchPackageNames": [
        "gcr.io/cloud-provider-vsphere/csi/release{/,}**",
        "quay.io/k8scsi{/,}**"
      ]
    },
    {
      "description": "Regroup Calico updates",
      "matchPackageNames": [
        "rke2-calico",
        "rke2-calico-crd"
      ],
      "versioning": "regex:^v(?<major>\\d+)(\\.(?<minor>\\d+))?(\\.(?<patch>\\d+))$",
      "groupName": "rke2-calico"
    },
    {
      "description": "Format rke2-ingress-nginx version",
      "matchPackageNames": [
        "rke2-ingress-nginx"
      ],
      "versioning": "regex:^(?<major>\\d+)(\\.(?<minor>\\d+))?(\\.(?<patch>\\d+))$"
    },
    {
      "description": "Format rke2-multus version",
      "matchPackageNames": [
        "rke2-multus"
      ],
      "versioning": "regex:^v(?<major>\\d+)(\\.(?<minor>\\d+))?\\.(?<patch>.*)"
    },
    {
      "description": "Regroup rancher-cis-benchmark updates",
      "matchPackageNames": [
        "rancher-cis-benchmark",
        "rancher-cis-benchmark-crd"
      ],
      "groupName": "rancher-cis-benchmark"
    },
    {
      "description": "Regroup rancher-logging updates",
      "matchPackageNames": [
        "rancher-logging",
        "rancher-logging-crd"
      ],
      "groupName": "rancher-logging"
    },
    {
      "description": "Regroup rancher-monitoring updates",
      "matchPackageNames": [
        "rancher-monitoring",
        "rancher-monitoring-crd"
      ],
      "groupName": "rancher-monitoring"
    },
    {
      "description": "Regroup longhorn updates",
      "matchPackageNames": [
        "longhorn",
        "longhorn-crd"
      ],
      "groupName": "longhorn"
    },
    {
      "description": "Regroup sriov updates",
      "matchPackageNames": [
        "sriov-network-operator",
        "sriov-crd"
      ],
      "groupName": "sriov"
    },
    {
      "description": "Format ironic version",
      "matchPackageNames": [
        "ironic"
      ],
      "versioning": "regex:^capm3-v(?<major>\\d+)(\\.(?<minor>\\d+))?(\\.(?<patch>\\d+))$"
    },
    {
      "description": "Regroup ironic and metal3 updates",
      "matchPackageNames": [
        "ironic",
        "metal3-io/cluster-api-provider-metal3"
      ],
      "groupName": "metal3"
    },
    {
      "description": "Prevent vault update to 1.14 due to licence issue",
      "matchPackageNames": [
        "hashicorp/vault"
      ],
      "allowedVersions": "<1.14"
    },
    {
      "description": "Prevent helm rancher update to over 105 for compatibility with rancher 2.10",
      "matchPackageNames": [
        "rancher-logging",
        "rancher-logging-crd",
        "rancher-monitoring-crd",
        "rancher-monitoring",
        "longhorn-crd",
        "longhorn"
      ],
      "allowedVersions": "<106"
    },
    {
      "description": "Regroup kube-job updates",
      "groupName": "kube-job",
      "matchPackageNames": [
        "/.*kube-job.*/"
      ]
    },
    {
      "description": "Regroup workload-cluster-operator updates",
      "groupName": "workload-cluster-operator",
      "matchPackageNames": [
        "/.*workload-cluster-operator.*/"
      ]
    },
    {
      "description": "Regroup sylva-units-operator updates",
      "groupName": "sylva-units-operator",
      "matchPackageNames": [
        "/.*sylva-units-operator.*/"
      ]
    },
    {
      "description": "Regroup heat-operator updates",
      "groupName": "heat-operator",
      "matchPackageNames": [
        "/.*heat-operator.*/"
      ]
    },
    {
      "description": "Regroup sylva-toolbox & ci-image updates",
      "groupName": "sylva-toolbox & ci-image",
      "matchPackageNames": [
        "/.*sylva-toolbox.*/",
        "/.*ci-image/"
      ]
    },
    {
      "description": "Catch all changes related to values files and run generate_units_documentation script",
      "matchFileNames": [
        "**/**values.yaml",
        "kustomize-units/**/**"
      ],
      "postUpgradeTasks": {
        "commands": [
          "pip install pyyaml",
          "tools/generate_units_documentation.py",
          "tools/generate_json_schema.py"
        ],
        "fileFilters": [
          "charts/sylva-units/units-description.md",
          "charts/sylva-units/values.schema.json"
        ],
        "executionMode": "update"
      }
    },
    {
      "description": "Run commands required to update Sylva library",
      "matchPackageNames": "sylva-library",
      "postUpgradeTasks": {
        "commands": [
          "helm dependency update charts/sylva-units"
        ],
        "fileFilters": [
          "charts/sylva-units/charts/sylva-library-*"
        ],
        "executionMode": "update"
      }
    }
  ],
  "customManagers": [
    {
      "description": "Generic regex to match variable ending in _VERSION in kubescore yaml file",
      "customType": "regex",
      "managerFilePatterns": [
        "/.gitlab/ci/tests/security/kubescore.yml/"
      ],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>.*?) depName=(?<depName>.*?)( VersionTemplate=(?<VersionTemplate>.*?))?\\s+.*?_VERSION.\\s\"?(?<currentValue>[^\"\\n]+)\"?\\n"
      ],
      "extractVersionTemplate": "{{#if VersionTemplate}}^{{{VersionTemplate}}}(?<version>.*)${{/if}}"
    },
    {
      "description": "Update Pylama in GitLab CI pipeline",
      "customType": "regex",
      "managerFilePatterns": [
        "/.gitlab/ci/.*.yml/"
      ],
      "matchStrings": [
        ".*pip install\\s+(?<depName>.*)==(?<currentValue>.*)"
      ],
      "datasourceTemplate": "pypi"
    },
    {
      "description": "Match docker image define in _IMAGE variables for gitlab-ci",
      "customType": "regex",
      "managerFilePatterns": [
        "/.gitlab/ci/.*.yml/"
      ],
      "matchStrings": [
        "\\s+# renovate: datasource=(?<datasource>.*?)\\s+.*?_IMAGE: (?<registryUrl>.*?)/(?<depName>.*?):(?<currentValue>.*)"
      ],
      "registryUrlTemplate": "https://{{{ registryUrl }}}"
    },
    {
      "description": "Match github releases defined via a direct link in kustomizations",
      "customType": "regex",
      "managerFilePatterns": [
        "/kustomization.y[a]?ml/"
      ],
      "matchStrings": [
        "https://github[.]com/(?<depName>.*/.*?)/releases/download/(?<currentValue>.*?)/"
      ],
      "datasourceTemplate": "github-releases"
    },
    {
      "description": "Match github tags defined via a direct link in kustomizations",
      "customType": "regex",
      "managerFilePatterns": [
        "/kustomization.y[a]?ml/"
      ],
      "matchStrings": [
        "https://raw.githubusercontent.com/(?<depName>[^/]*/[^/]*)/(?<currentValue>.*?)/"
      ],
      "datasourceTemplate": "github-tags"
    },
    {
      "description": "Match Helm charts in helm repository defined under units",
      "customType": "regex",
      "managerFilePatterns": [
        "/charts/sylva-units/values.yaml/"
      ],
      "matchStringsStrategy": "recursive",
      "matchStrings": [
        "units:[\\w\\W]*[ ]+",
        "\\n\\s+helm_repo_url:(?<registryUrl>.*)\\n[\\w\\W]*?chart: (?<depName>.*)\\n[\\w\\W]*?version: (?<currentValue>.*)\\n"
      ],
      "datasourceTemplate": "helm"
    },
    {
      "description": "Match Sylva diskimagebuilder",
      "customType": "regex",
      "managerFilePatterns": [
        "/charts/sylva-units/values.yaml/"
      ],
      "matchStrings": [
        "#\\s?renovate: depName=(?<depName>.*?)\\n*?sylva_diskimagebuilder_version: (?<currentValue>.*)"
      ],
      "datasourceTemplate": "gitlab-tags"
    },
    {
      "description": "Match images used by operators",
      "customType": "regex",
      "managerFilePatterns": [
        "/kustomize-units/*/kustomization.yaml/"
      ],
      "matchStrings": [
        "\\n\\s+newName:\\s+(?<registryUrl>.*?)/(?<depName>.*)\\n[\\w\\W]*?newTag:\\s+\"?(?<currentValue>[^\"\\n]+)\"?"
      ],
      "registryUrlTemplate": "https://{{{ registryUrl }}}",
      "datasourceTemplate": "docker"
    },
    {
      "description": "Match Helm charts in git repository defined under units",
      "customType": "regex",
      "managerFilePatterns": [
        "/charts/sylva-units/values.yaml/"
      ],
      "matchStringsStrategy": "recursive",
      "matchStrings": [
        "source_templates:[\\w\\W]*[ ]+",
        "\\n\\s+url:\\s(?<depName>.*)\\n[\\w\\W]*?(branch:|tag:|commit:) (?<currentValue>.*)\\n"
      ],
      "datasourceTemplate": "git-tags"
    },
    {
      "description": "Generic match for docker images in values.yaml, looking for repository: / tag: pattern",
      "customType": "regex",
      "managerFilePatterns": [
        "/charts/sylva-units/values.yaml/"
      ],
      "matchStrings": [
        "\\s+repository:\\s+(?<registryUrl>.*)/(?<depName>.*)\\n\\s+tag:\\s\"?(?<currentValue>[^\"\\n]+)\"?\\n"
      ],
      "registryUrlTemplate": "https://{{{ registryUrl }}}",
      "datasourceTemplate": "docker"
    },
    {
      "description": "Detect keycloak-realm-operator version",
      "customType": "regex",
      "datasourceTemplate": "docker",
      "managerFilePatterns": [
        "/kustomize-units/keycloak-legacy-operator/kustomization.yaml/"
      ],
      "matchStrings": [
        "#\\s?renovate: registryUrl=(?<registryUrl>.*?) image=(?<depName>.*?)\\n[\\w\\W]*?newTag: (?<currentValue>[\\w+.-]*)"
      ]
    },
    {
      "description": "Detect vault docker image",
      "customType": "regex",
      "datasourceTemplate": "docker",
      "managerFilePatterns": [
        "/vault.yaml/"
      ],
      "matchStrings": [
        "spec:\\n[\\w\\W]*?.*image: (?<depName>.*)\\:(?<currentValue>.*)"
      ]
    },
    {
      "description": "Detect Sylva-toolbox image in common.sh",
      "customType": "regex",
      "managerFilePatterns": [
        "/tools/shell-lib/common.sh/"
      ],
      "matchStringsStrategy": "combination",
      "matchStrings": [
        "SYLVA_TOOLBOX_VERSION:-\"(?<currentValue>.*)\".",
        "SYLVA_TOOLBOX_IMAGE:-(?<depName>.*).",
        "SYLVA_BASE_OCI_REGISTRY:-(?<base_registryUrl>.*).",
        "SYLVA_TOOLBOX_REGISTRY:-.*/(?<uri_registryUrl>.*)."
      ],
      "registryUrlTemplate": "https://{{{ base_registryUrl }}}/{{{ uri_registryUrl }}}",
      "datasourceTemplate": "docker"
    },
    {
      "description": "Match generic comment in values file, used to detect version change in kustomize patch",
      "customType": "regex",
      "managerFilePatterns": [
        "/charts/sylva-units/values.yaml/",
        "/charts/sylva-units/templates/delete_hook.yaml/"
      ],
      "matchStrings": [
        "#\\s?renovate: datasource=(?<datasource>.*?)\\n\\s+.*?:\\s*(?<depName>(?<registryUrl>[^/]*)/.*):(?<currentValue>.*)"
      ],
      "registryUrlTemplate": "https://{{{ registryUrl }}}"
    }
  ],
  "prFooter": "This PR has been generated by [Renovate Bot Sylva instance](https://gitlab.com/sylva-projects/sylva-elements/renovate).\n\nCI configuration couldn't be handle by PR description. A dedicated comment has been posted to control it.\n\nIf no checkbox is checked, a default pipeline will be enabled (capm3, or capo if ~capo label is set)\n\n"
}
